---
import Breadcrumbs from "@/components/breadcrumbs.astro";
import PrefixesTable from "@/components/prefixes-table.astro";
import Layout from "@/layouts/main.astro";
import { raids } from "@/store/raids";

interface OwnerWithServicePointName {
  servicePointName?: string;
  [key: string]: unknown;
}

const prefixData = new Map<string, { count: number; servicePointName: string }>();

for (const el of raids) {
  const [_, prefix] = new URL(el.identifier.id).pathname.split("/");
  const existing = prefixData.get(prefix);
  const owner = el.identifier.owner as unknown as OwnerWithServicePointName;

  if (existing) {
    existing.count++;
  } else {
    prefixData.set(prefix, {
      count: 1,
      servicePointName: owner?.servicePointName || "Unknown",
    });
  }
}
---

<Layout title="main">
  <div class="overflow-hidden rounded-md bg-white border border-gray-300">
    <Breadcrumbs elements={[{ to: "/prefixes", label: "Prefixes" }]} />
    <div class="p-4 sm:p-6 lg:p-8">
      <div class="sm:flex sm:items-center">
        <div class="sm:flex-auto">
          <h1 class="text-base font-semibold leading-6 text-gray-900">
            Prefixes
          </h1>
          <p class="mt-2 text-sm text-gray-700">A list of all the prefixes</p>
        </div>
      </div>
      <PrefixesTable prefixes={prefixData} />
    </div>
  </div>
</Layout>
