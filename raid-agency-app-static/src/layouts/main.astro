---
import Navbar from "@/components/navbar.astro";
import TopBar from "@/components/top-bar.astro";
import Footer from "@/components/footer.astro";

import "@fontsource/figtree";

import GoogleAnalytics from '@/components/google-analytics.astro';
import Banner from "@/components/raid-components/banner.astro";
import { getSiteConfig } from "@/config";

const { topBar } = getSiteConfig().header;

interface Props {
  title: string;
}

const { title } = Astro.props;
// Only show banner in non-production environments
const raidEnv = import.meta.env.RAID_ENV;
const isProduction = raidEnv === 'prod';
const shouldRender = !isProduction;
---

<!doctype html>
<html lang="en" class="min-h-dvh">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <style>
      body {
        font-family: "Figtree";
      }
    </style>
    <GoogleAnalytics />
  </head>
  <body class=`${topBar.show && "min-h-dvh" } flex flex-col bg-[#c6d9f0] dark:bg-[#1b3e60]`>
    <!-- ARDC Top Bar (only renders when USE_CUSTOM_CONFIG=true) -->
    <TopBar />

    <!-- Main Content Card -->
    <div
      class="m-7 w-full mx-auto max-w-7xl flex-1 rounded-md border border-gray-300 bg-white shadow-md"
    >
      <Navbar />
      {shouldRender && (
        <Banner
          variant="warning"
          message="This is is not a production RAiD and it should only be used for demonstration purposes."
          dismissible={false}
        />
      )}
      <main class="px-4 py-8 sm:px-6 lg:px-8">
        <slot />
      </main>
    </div>

    <!-- ARDC Footer (only renders when USE_CUSTOM_CONFIG=true) -->
    <Footer />
  </body>
</html>
