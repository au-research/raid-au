---
import Navbar from "@/components/navbar.astro";
import TopBar from "@/components/top-bar.astro";
import Footer from "@/components/footer.astro";

import "@fontsource/figtree";
import "@/styles/global.css";

import GoogleAnalytics from '@/components/google-analytics.astro';
import Banner from "@/components/raid-components/banner.astro";
import { getSiteConfig } from "@/config";

const config = getSiteConfig();
const { topBar } = config.header;

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  lastModified?: string;
}

const { title, description, noindex = false, lastModified } = Astro.props;
// Only show banner in non-production environments
const isProduction = config.raidEnv === 'prod';
const shouldRender = !isProduction;
---

<!doctype html>
<html lang="en" class="min-h-dvh">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description ?? "RAiD — Research Activity Identifier"} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {lastModified && <meta name="last-modified" content={lastModified} />}
    <title>{title}</title>
    <style>
      body {
        font-family: "Figtree";
      }
    </style>
    <GoogleAnalytics />
  </head>
  <body class=`${topBar.show && "min-h-dvh" } flex flex-col bg-[#c6d9f0] dark:bg-[#1b3e60]`>
    <!-- Top Bar (only renders when header.topBar.show=true in app-config.json) -->
    <TopBar />

    <!-- Main Content Card -->
    <div
      class="m-7 w-full mx-auto max-w-7xl flex-1 rounded-md border border-gray-300 bg-white shadow-md"
    >
      <Navbar />
      {shouldRender && (
        <Banner
          variant="warning"
          message="This is is not a production RAiD and it should only be used for demonstration purposes."
          dismissible={false}
        />
      )}
      <main class="px-4 py-8 sm:px-6 lg:px-8">
        <slot />
      </main>
    </div>

    <!-- Footer (only renders when footer.show=true in app-config.json) -->
    <Footer />
  </body>
</html>
