---
/**
 * Google Analytics — loaded at runtime from /app-config.json.
 *
 * Fetching client-side means the GA measurement ID can be updated by
 * replacing /app-config.json on S3 or via a Docker volume mount without
 * rebuilding the site. Only fires on hostnames containing "prod" or "demo".
 */
---
<script is:inline>
  (async function () {
    try {
      var res = await fetch("/app-config.json");
      if (!res.ok) return;
      var cfg = await res.json();

      var hostname = window.location.hostname;
      var isProd = hostname.includes("prod");
      var isDemo = hostname.includes("demo");

      var gaId = isProd
        ? cfg.analytics && cfg.analytics.gaMeasurementId
        : isDemo
          ? cfg.analytics && cfg.analytics.gaMeasurementIdDemo
          : null;

      if (!gaId) return;

      var s = document.createElement("script");
      s.src = "https://www.googletagmanager.com/gtag/js?id=" + gaId;
      s.async = true;
      document.head.appendChild(s);

      window.dataLayer = window.dataLayer || [];
      window.gtag = function gtag() { window.dataLayer.push(arguments); };
      window.gtag("js", new Date());
      window.gtag("config", gaId);
    } catch (_) {
      // GA is non-critical — fail silently
    }
  })();
</script>
