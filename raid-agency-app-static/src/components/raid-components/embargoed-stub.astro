---
import InfoField from "@/components/info-field.astro";
import type { EmbargoedRaidSummary } from "@/store/embargoed-raids";

interface Props {
  raid: EmbargoedRaidSummary;
}

const { raid } = Astro.props as Props;
---

<section class="bg-gray-50 py-5">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h3 class="text-lg font-semibold text-gray-900">Access</h3>
    <div class="divide-y divide-gray-200">
      <div class="ml-5 space-y-2 py-4">
        <div class="grid grid-cols-3 gap-5 text-sm">
          <InfoField label="Status" value={raid.embargoedStatusLabel} />
          <InfoField
            label="Embargo Expiry"
            value={raid.embargoExpiry ?? "Not specified"}
          />
          <InfoField
            label="Access Statement"
            value={raid.accessStatement ?? "No access statement provided."}
          />
        </div>
      </div>
    </div>
  </div>
</section>

<section class="bg-white py-5">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h3 class="text-lg font-semibold text-gray-900">Registration Agency</h3>
    <div class="divide-y divide-gray-200">
      <div class="ml-5 space-y-2 py-4">
        <div class="grid grid-cols-2 gap-5 text-sm">
          <InfoField label="Name" value={raid.registrationAgencyName} />
          <div>
            <span class="block font-medium text-gray-900">Identifier</span>
            {raid.registrationAgencyRor ? (
              <a href={raid.registrationAgencyRor} target="_blank">
                <img style="display: inline; margin-right: 2px" src="/ror-icon.png" alt="ror-icon" height="24" />
                <span style="text-decoration: underline">{raid.registrationAgencyRor}</span>
              </a>
            ) : (
              <span class="text-gray-500">—</span>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="bg-gray-50 py-5">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h3 class="text-lg font-semibold text-gray-900">Service Point</h3>
    <div class="divide-y divide-gray-200">
      <div class="ml-5 space-y-2 py-4">
        <div class="grid grid-cols-1 gap-5 text-sm">
          <InfoField label="Name" value={raid.servicePointName || "—"} />
        </div>
      </div>
    </div>
  </div>
</section>

<section class="bg-white py-5">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h3 class="text-lg font-semibold text-gray-900">Owning Organisation</h3>
    <div class="divide-y divide-gray-200">
      <div class="ml-5 space-y-2 py-4">
        <div class="grid grid-cols-2 gap-5 text-sm">
          <InfoField label="Name" value={raid.ownerName} />
          <div>
            <span class="block font-medium text-gray-900">Identifier</span>
            {raid.ownerRor ? (
              <a href={raid.ownerRor} target="_blank">
                <img style="display: inline; margin-right: 2px" src="/ror-icon.png" alt="ror-icon" height="24" />
                <span style="text-decoration: underline">{raid.ownerRor}</span>
              </a>
            ) : (
              <span class="text-gray-500">—</span>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
